{
  "name": "smart-city-complaint-portal",
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_APP_NAME": "Smart City Complaint Portal",
    "NODE_ENV": "production"
  }
}
